{
  "lexicon": 1,
  "id": "place.stream.live.metadata",
  "defs": {
    "main": {
      "type": "record",
      "description": "Metadata record for livestream content including warnings, rights, and distribution policy",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["createdAt"],
        "properties": {
          "createdAt": {
            "type": "string",
            "format": "datetime",
            "description": "iso 8601 with timezone; mirrored to c2pa.metadata (dc:created/xmp:CreateDate)."
          },
          "contentWarnings": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "death",
                "drugUse",
                "fantasyViolence",
                "flashingLights",
                "language",
                "nudity",
                "personalInformation",
                "sexuality",
                "suffering",
                "violence"
              ]
            },
            "description": "prefer contentWarningUris as it maps to iptc uris."
          },
          "contentWarningUris": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uri"
            },
            "description": "uris from iptc content warning vocabulary (https://cv.iptc.org/newscodes/contentwarning/). these are written into c2pa."
          },
          "contentWarningScheme": {
            "type": "string",
            "format": "uri",
            "default": "https://cv.iptc.org/newscodes/contentwarning/",
            "description": "controlled vocabulary scheme uri."
          },
          "rights": {
            "type": "ref",
            "ref": "#rights"
          },
          "distributionPolicy": {
            "type": "ref",
            "ref": "#distributionPolicy"
          },
          "c2pa": {
            "type": "object",
            "properties": {
              "manifestUrl": {
                "type": "string",
                "format": "uri",
                "description": "where the c2pa manifest can be fetched if not embedded."
              },
              "instanceId": {
                "type": "string",
                "description": "c2pa instance id for this asset, if known."
              }
            }
          },
          "livestreamRef": {
            "type": "ref",
            "ref": "com.atproto.repo.strongRef",
            "description": "reference to the livestream this metadata applies to."
          }
        }
      }
    },
    "rights": {
      "type": "object",
      "description": "content rights and attribution",
      "properties": {
        "attribution": {
          "type": "string",
          "maxLength": 100,
          "description": "display credit line; maps to photoshop:Credit."
        },
        "creators": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 100
          },
          "description": "list of creators; maps to dc:creator."
        },
        "copyright": {
          "type": "string",
          "maxLength": 200,
          "description": "copyright notice; maps to photoshop:CopyrightNotice."
        },
        "copyrightYear": {
          "type": "string",
          "maxLength": 4
        },
        "license": {
          "type": "string",
          "enum": [
            "all-rights-reserved",
            "cc0",
            "cc-by",
            "cc-by-sa",
            "cc-by-nc",
            "cc-by-nc-sa",
            "cc-by-nd",
            "cc-by-nc-nd",
            "custom"
          ],
          "description": "ui hint. source of truth is licenseUrl and usageTerms."
        },
        "licenseUrl": {
          "type": "string",
          "format": "uri",
          "description": "canonical license page; maps to xmpRights:WebStatement."
        },
        "usageTerms": {
          "type": "string",
          "maxLength": 500,
          "description": "human-readable terms; maps to xmpRights:UsageTerms."
        }
      }
    },
    "distributionPolicy": {
      "type": "object",
      "required": ["allowBroadcast", "allowArchive", "broadcastUntil"],
      "description": "also emitted as a custom c2pa assertion label: place.stream.distribution/v1",
      "properties": {
        "policyId": {
          "type": "string",
          "description": "uuid"
        },
        "policyVersion": {
          "type": "string",
          "description": "e.g. 2025-08-12"
        },
        "allowBroadcast": {
          "type": "boolean"
        },
        "allowArchive": {
          "type": "boolean"
        },
        "broadcastUntil": {
          "type": "string",
          "enum": ["forever", "1year", "1month", "1day", "custom"]
        },
        "customDuration": {
          "type": "string",
          "format": "datetime",
          "description": "required when broadcastUntil is 'custom'."
        }
      }
    }
  }
}
