{
  "name": "aquareum",
  "main": "./src/entrypoint.tsx",
  "version": "0.2.3",
  "runtimeVersion": "0.2.3",
  "scripts": {
    "upgrade:tamagui": "yarn up '*tamagui*'@latest '@tamagui/*'@latest",
    "upgrade:tamagui:canary": "yarn up '*tamagui*'@canary '@tamagui/*'@canary",
    "start": "npx expo start -c --port 38081",
    "android": "expo run:android --port 38081 \"$@\"",
    "ios": "expo run:ios --port 38081",
    "web": "npx expo start --web --port 38081",
    "test": "jest --watchAll",
    "build": "yarn run build:web && yarn run prebuild",
    "build:web": "yarn run export && node exportClientExpoConfig.js > dist/expoConfig.json",
    "export": "expo export --dump-sourcemap || expo export --dump-sourcemap",
    "check": "bash -c 'export OUT=$(mktemp -d); npx tsc -p . --outDir $OUT; rm -rf $OUT'",
    "prebuild": "EXPO_NO_GIT_STATUS=1 expo prebuild --clean && sed -i.bak 's/org.gradle.jvmargs=-Xmx2048m -XX:MaxMetaspaceSize=512m/org.gradle.jvmargs=-Xmx8192m -XX:MaxMetaspaceSize=2048m/' android/gradle.properties && echo '\nnetworkTimeout=100000' >> android/gradle.properties && sed -i.bak  's/plugins { id(\"com.facebook.react.settings\") }//' android/settings.gradle && yarn run find-node",
    "postinstall": "which pod && yarn run postinstall-ios || echo 'not a mac, not installing pods'",
    "postinstall-ios": "cd ios && pod install && yarn run find-node",
    "find-node": "node -p '`NODE_BINARY=${process.argv[0]}`' > ios/.xcode.env.local",
    "code-signing-dev": "mkdir -p code-signing-dev/keys code-signing-dev/certs && expo-updates codesigning:generate --key-output-directory code-signing-dev/keys --certificate-output-directory code-signing-dev/certs --certificate-validity-duration-years 10 --certificate-common-name 'Aquareum'"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@rainbow-me/rainbowkit": "2.2.0",
    "@react-native-firebase/app": "^21.3.0",
    "@react-native-firebase/messaging": "^21.3.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/drawer": "^6.7.2",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@tamagui/config": "^1.116.12",
    "@tamagui/lucide-icons": "^1.116.12",
    "@tamagui/toast": "^1.116.12",
    "@tanstack/react-query": "^5.59.19",
    "babel-preset-expo": "^11.0.15",
    "burnt": "^0.12.2",
    "chrono-node": "^2.7.7",
    "expo": "~51.0.38",
    "expo-build-properties": "^0.12.5",
    "expo-dev-client": "~4.0.28",
    "expo-font": "~12.0.10",
    "expo-linking": "~6.3.1",
    "expo-notifications": "~0.28.19",
    "expo-splash-screen": "~0.27.6",
    "expo-status-bar": "^1.12.1",
    "expo-system-ui": "~3.0.7",
    "expo-updates": "~0.25.27",
    "expo-video": "^1.2.7",
    "expo-web-browser": "~13.0.3",
    "hls.js": "^1.5.17",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.74.6",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.14.0",
    "react-native-screens": "3.35.0",
    "react-native-svg": "15.8.0",
    "react-native-web": "^0.19.13",
    "react-native-webview": "13.12.3",
    "tamagui": "^1.116.12",
    "ua-parser-js": "^2.0.0-rc.1",
    "uuid": "^11.0.2",
    "viem": "^2.21.40",
    "wagmi": "2.12.25"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/plugin-proposal-export-default-from": "^7.25.9",
    "@babel/plugin-syntax-export-default-from": "^7.25.9",
    "@babel/plugin-transform-flow-strip-types": "^7.25.9",
    "@babel/plugin-transform-private-methods": "^7.25.9",
    "@babel/plugin-transform-private-property-in-object": "^7.25.9",
    "@babel/plugin-transform-runtime": "^7.25.9",
    "@expo/metro-config": "~0.18.11",
    "@expo/metro-runtime": "~3.2.3",
    "@tamagui/babel-plugin": "^1.116.12",
    "@tamagui/metro-plugin": "^1.116.12",
    "@types/babel__plugin-transform-runtime": "^7",
    "@types/react": "~18.3.12",
    "@types/uuid": "^10.0.0",
    "typescript": "~5.6.3"
  },
  "private": true
}
