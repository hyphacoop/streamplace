# Common UI Translations - French (France)

## General UI
loading = Chargement...
error = Erreur
cancel = Annuler
confirm = Confirmer
close = Fermer
open = Ouvrir
ok = OK
yes = Oui
no = Non
continue = Continuer
back = Retour
next = Suivant
finish = Terminer

## Actions
save = Enregistrer
delete = Supprimer
edit = Modifier
create = Créer
update = Mettre à jour
refresh = Actualiser

## Status Messages
success = Succès
warning = Avertissement
info = Information

## Input Placeholders
search-placeholder = Rechercher...
message-input = Entrez votre message...

## Demo and Testing
welcome-user = Bienvenue, { $username } !
notification-count = { $count ->
    [0] Aucune notification
    [1] Une notification
   *[other] { $count } notifications
}
