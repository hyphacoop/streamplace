{
  "extends": "../app/tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "jsx": "react-jsx",
    "module": "commonjs",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true
  },
  "include": ["./src"],
  "ts-node": {
    "compilerOptions": {
      "resolveJsonModule": true
    }
  }
}
