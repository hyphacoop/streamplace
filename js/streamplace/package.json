{
  "name": "streamplace",
  "version": "0.7.21",
  "description": "Live video on the AT Protocol",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "@streamplace/dev": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepare": "cd ../.. && make js-lexicons && cd - && pnpm run build && pnpm run test-import",
    "test-import": "node -e 'require(\".\")' || (echo 'require(\".\") failed, npm package is not working' && exit 1)",
    "start": "tsc --watch --preserveWatchOutput"
  },
  "keywords": [
    "streamplace",
    "livepeer",
    "atproto"
  ],
  "author": "Streamplace",
  "license": "MIT",
  "packageManager": "pnpm@10.11.0",
  "dependencies": {
    "@atproto/api": "^0.16.7",
    "@atproto/lexicon": "^0.5.0",
    "@atproto/xrpc": "^0.7.4",
    "multiformats": "^9.9.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "typescript": "~5.3.3"
  }
}
