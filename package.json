{
  "name": "streamplace-monorepo",
  "private": true,
  "version": "0.0.0-monorepo",
  "description": "The video layer for everything.",
  "main": "index.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "preinstall": "node hack/node-version.js",
    "check": "pnpm run check:workspaces && git ls-files | xargs prettier --check --ignore-unknown",
    "check:workspaces": "cd js/app && pnpm run check",
    "fix": "git ls-files | xargs prettier --write --ignore-unknown",
    "postinstall": "husky && make js-lexicons",
    "build": "pnpm --stream -r run build",
    "prepare": "husky",
    "release": "lerna publish --force-publish",
    "precommit": "make precommit",
    "app": "cd js/app && pnpm run \"$@\"",
    "desktop": "cd js/desktop && pnpm run \"$@\"",
    "docs": "cd js/docs && pnpm run \"$@\"",
    "start": "pnpm --stream --parallel -r run start"
  },
  "keywords": [],
  "author": "Streamplace",
  "license": "MIT",
  "devDependencies": {
    "@atproto/lex-cli": "^0.5.6",
    "husky": "^9.1.6",
    "lerna": "^8.1.9",
    "lint-staged": "^15.2.10",
    "prettier": "3.4.2"
  },
  "workspaces": [
    "js/*"
  ],
  "dependencies": {
    "firebase-admin": "^12.7.0",
    "lex-md": "^0.0.3"
  },
  "packageManager": "pnpm@10.11.0+sha512.6540583f41cc5f628eb3d9773ecee802f4f9ef9923cc45b69890fb47991d4b092964694ec3a4f738a420c918a333062c8b925d312f42e4f0c263eb603551f977"
}
